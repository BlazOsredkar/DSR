@model _1_test.Models.Book
@{
    ViewData["Title"] = "Obrazec knjiga";
}

<div class="card-panel">
    <h1>Obrazec knjiga (EditorForModel)</h1>
    <p class="form-note">Po kliku na Naprej se prikaze predogled (PRG).</p>

    <form asp-action="BookForm" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        @Html.EditorForModel()

        <div class="form-section">
            <button type="submit" class="btn btn-primary">Naprej</button>
        </div>
    </form>
</div>
