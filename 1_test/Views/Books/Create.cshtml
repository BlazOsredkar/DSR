@model _1_test.Models.Book
@{
    ViewData["Title"] = "Dodaj knjigo";
}

<div class="card-panel">
    <h1>Dodaj knjigo</h1>
    <p class="form-note">Uporabljeni so EditorTemplates za Int32/Double/DateTime.</p>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        @Html.EditorForModel()

        <div class="form-section">
            <button type="submit" class="btn btn-primary">Shrani</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Nazaj</a>
        </div>
    </form>
</div>
