@model _1_test.Models.ViewModels.RegistrationSessionModel
@{
    ViewData["Title"] = "Registracija - povzetek";
}

<div class="card-panel">
    <h1>Registracija - povzetek</h1>
    <p class="form-note">Izpis vseh vpisanih podatkov.</p>

    <table class="table">
        <tbody>
            <tr><th>Ime</th><td>@Model.FirstName</td></tr>
            <tr><th>Priimek</th><td>@Model.LastName</td></tr>
            <tr><th>Datum rojstva</th><td>@Model.BirthDate.ToString("dd.MM.yyyy")</td></tr>
            <tr><th>EMSO</th><td>@Model.Emso</td></tr>
            <tr><th>Starost</th><td>@Model.Age</td></tr>
            <tr><th>Naslov</th><td>@Model.Address</td></tr>
            <tr><th>Postna stevilka</th><td>@Model.PostalCode</td></tr>
            <tr><th>Posta</th><td>@Model.City</td></tr>
            <tr><th>Drzava</th><td>@Model.Country</td></tr>
            <tr><th>E-posta</th><td>@Model.Email</td></tr>
            <tr><th>Geslo</th><td>@Model.Password</td></tr>
            <tr><th>Ponovitev gesla</th><td>@Model.ConfirmPassword</td></tr>
        </tbody>
    </table>

    <a class="btn btn-outline-secondary" asp-action="Step1">Nazaj na 1. korak</a>
</div>
