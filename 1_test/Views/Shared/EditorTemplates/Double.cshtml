@model double?
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using System.Linq
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var fieldName = ViewData.TemplateInfo.GetFullHtmlFieldName(string.Empty);
    var fieldId = TagBuilder.CreateSanitizedId(fieldName, "_");
    var range = ViewData.ModelMetadata.ValidatorMetadata.OfType<RangeAttribute>().FirstOrDefault();
    var min = range?.Minimum ?? 0.0;
    var max = range?.Maximum ?? 100.0;
    var value = Model ?? 0.0;
    var formatted = value.ToString("0.##", CultureInfo.InvariantCulture);
}

<!-- Naloga: Double slider (navodilo: "Tipu Double ... se pri urejanju izrise slider"). -->
<div class="slider-field">
    <input type="text"
           id="@fieldId"
           name="@fieldName"
           value="@formatted"
           class="form-control js-slider-input"
           data-min="@min"
           data-max="@max"
           data-step="0.1" />
    <div class="js-slider" data-target="#@fieldId"></div>
</div>
